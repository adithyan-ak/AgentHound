FROM node:20-alpine AS ui-builder
WORKDIR /ui
COPY server/ui/package.json server/ui/package-lock.json ./
RUN npm ci --ignore-scripts
COPY server/ui/ .
RUN npm run build

FROM golang:1.25-alpine AS builder
WORKDIR /src
ARG VERSION=dev
ARG COMMIT=none
COPY go.mod go.sum ./
RUN go mod download
COPY . .
COPY --from=ui-builder /ui/dist ./server/internal/api/ui/dist
RUN CGO_ENABLED=0 GOOS=linux go build \
    -trimpath \
    -ldflags="-s -w -X main.version=${VERSION} -X main.commit=${COMMIT}" \
    -o /bin/agenthound-server \
    ./server/cmd/agenthound-server

FROM alpine:3.19
RUN apk add --no-cache ca-certificates && adduser -D -u 1001 agenthound
COPY --from=builder /bin/agenthound-server /usr/local/bin/agenthound-server
EXPOSE 8080
USER 1001
ENTRYPOINT ["agenthound-server"]
CMD ["serve"]
